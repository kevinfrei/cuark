{
  "name": "my-cuark-app",
  "version": "0.1.1",
  "private": false,
  "scripts": {
    "cfmt": "passable -i -q \"CMakeLists.txt\" \"src/**/CMakeLists.txt\" \"src/**/*.cmake\" \".cuark/*.cmake\"",
    "format": "tools format && bun run cfmt",
    "fmt": "bun run format",
    "clean": "bun run .cuark/clean.ts",
    "dcfg": "cmake --preset debug",
    "rcfg": "cmake --preset release",
    "cfg": "bun run dcfg",
    "dcpp": "cmake --build build/Debug",
    "rcpp": "cmake --build build/Release",
    "cpp": "bun run dcpp",
    "dwww": "bun run .cuark/webbuild.ts Debug",
    "rwww": "bun run .cuark/webbuild.ts Release",
    "www": "bun run dwww",
    "dbld": "bun run .cuark/parbld.ts Debug",
    "rbld": "bun run .cuark/parbld.ts Release",
    "bld": "bun run dbld",
    "dtst": "bun run dcpp && cd build/Debug && ctest --output-on-failure",
    "dtest": "bun run dcpp && cd build/Debug && ctest --output-on-failure",
    "rtst": "bun run rcpp && cd build/Release && ctest",
    "rtest": "bun run rcpp && cd build/Release && ctest",
    "tst": "bun run dtst",
    "test": "bun run dtst",
    "drun": "bun run os drun",
    "rrun": "bun run os rrun",
    "drun:win": "cmd /c build\\\\Debug\\\\src\\\\my-cuark-app.exe",
    "rrun:win": "cmd /c build\\\\Release\\\\src\\\\my-cuark-app.exe",
    "drun:mac": "./build/Debug/src/my-cuark-app",
    "rrun:mac": "./build/Release/src/my-cuark-app",
    "drun:lin": "./build/Debug/src/my-cuark-app",
    "rrun:lin": "./build/Release/src/my-cuark-app",
    "run": "bun run drun",
    "dbr": "bun run dbld && bun run drun",
    "rbr": "bun run rbld && bun run rrun",
    "br": "bun run dbr",
    "typecheck": "tsc --noEmit",
    "typechk": "tsc --noEmit",
    "***": "Generate the TypeScript & C++ types from the Crow IDL definitions",
    "gen": "crow-idl web/Shared/CuarkDefs.ts -c:src/ipc/CommonTypes.hpp -t:web/Shared/CommonTypes.ts",
    "*-*": "Helper to do OS-specific things",
    "os": "bun run .cuark/os.ts",
    "prepare": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged",
    "pre-push": "bun run test"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write"
    ],
    "*.cmake": [
      "passable -i"
    ],
    "CMakeLists.txt": [
      "passable -i"
    ],
    "*.{cpp,hpp,c,h,cc,hh}": [
      "clang-format -i"
    ]
  },
  "dependencies": {
    "@fluentui/react": "^8.125.5",
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-icons-mdl2": "^1.4.5",
    "@freik/fluentui-tools": "^1.2.10",
    "@freik/logger": "^0.4.10",
    "@freik/react-tools": "^0.3.10",
    "@freik/seqnum": "^1.3.10",
    "@freik/typechk": "^0.9.6",
    "jotai": "^2.20.0",
    "jotai-family": "^1.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@freik/passable": "^0.2.1",
    "@freik/ts-cpp-tooling": "^0.5.1",
    "@freik/workspace": "^0.8.1",
    "@types/bun": "^1.3.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "clang-format": "^1.8.0",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  }
}
